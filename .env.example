# ─── Cloudinary credentials (server-side, Vercel API) ───────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Cloudinary folder names (public, used by frontend) ─────────────────────
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_GALLERY_FOLDER=Portfolio-Gallery
VITE_CLOUDINARY_FEATURED_FOLDER=Portfolio-Featured
VITE_CLOUDINARY_SHOWCASE_FOLDER=Portfolio-Showcase

# ─── Admin panel password ────────────────────────────────────────────────────
ADMIN_PASSWORD=your_secure_password
VITE_ADMIN_PASSWORD=your_secure_password

# ─── Optional: URL of your deployed API for local dev ───────────────────────
# VITE_API_BASE_URL=https://your-deployed-project.vercel.app/api/list-images
